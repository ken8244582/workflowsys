# ============================================================================
# 服务器本地 Supabase 部署环境变量模板（.env.example）
# 用法（远程 Linux 服务器）：
#   cp .env.example .env.local   # 或直接写入服务器环境变量
# 注意：本文件不含云端值；所有值均指向服务器本机自托管的 Supabase。
# ============================================================================

# ---- JWT 签名密钥（supabase start 与前端应用必须一致，否则现有 token 失效）----
JWT_SECRET=fWMD+ty63ZaP+tC/a+c/UFvLe80UoDP6k8flyiqbHkI=

# ---- 本地 Supabase（Docker 自托管，supabase start 后本机监听 54321）----
# URL 固定指向本机；若 Supabase 与前端不在同一主机，改为服务器局域网 IP。
COZE_SUPABASE_URL=http://127.0.0.1:54321

# 下方为 Supabase 演示默认值，需与 supabase/config.toml 的 jwt_secret 保持一致。
# 若服务器 supabase status 输出的 key 与下方不同，请以 supabase status 为准覆盖。
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.DaYlNEoKiSYjafD-9gywC6GXPHjIYzjxZpJFQRa0f1k

# 服务器正式环境设为 PROD（决定 Cookie secure、prod 模式启动）
COZE_PROJECT_ENV=PROD

# 应用监听端口
PORT=5000
